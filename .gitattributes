# =========================
# Normalize text files
# =========================
* text=auto

# =========================
# Scripts
# =========================
/gradlew        text eol=lf
*.sh            text eol=lf
*.bat           text eol=crlf

# =========================
# Java / source files
# =========================
*.java          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.properties    text eol=lf
*.xml           text eol=lf
*.md            text eol=lf

# =========================
# Binary files
# =========================
*.jar           binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.zip           binary
